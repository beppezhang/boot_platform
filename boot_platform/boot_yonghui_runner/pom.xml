            <version>1.0.1-SNAPSHOT</version>
        </dependency>


        <dependency>
            <groupId>com.yonghui</groupId>
            <artifactId>makeup-client</artifactId>
            <version>1.0-SNAPSHOT</version>
        </dependency>

        <dependency>
            <groupId>com.yonghui</groupId>
            <artifactId>order-common-center-api</artifactId>
            <version>1.0.1-SNAPSHOT</version>
